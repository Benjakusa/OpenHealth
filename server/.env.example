# Server Configuration
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openhealth
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Encryption (for offline sync)
ENCRYPTION_KEY=your_32_char_encryption_key_here

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=your_shortcode
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=http://localhost:3000/api/payments/callback
MPESA_B2C_SHORTCODE=your_b2c_shortcode
MPESA_B2C_CALLBACK_URL=http://localhost:3000/api/payments/b2c-callback
MPESA_ENV=sandbox

# SHA/AfyaLink Integration
SHA_BASE_URL=https://uat.shamafya.go.ke
SHA_CLIENT_ID=your_sha_client_id
SHA_CLIENT_SECRET=your_sha_client_secret
SHA_CALLBACK_URL=http://localhost:3000/api/claims/callback

# SMS - Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SMS - Africa's Talking
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_USERNAME=your_username

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=OpenHealth
SMTP_FROM_EMAIL=noreply@openhealth.co.ke

# App URLs
CLIENT_APP_URL=openhealth://
FRONTEND_URL=http://localhost:8080
